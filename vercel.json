{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "cd .. && pnpm build --filter @how-to-talk-corporate/web",
  "installCommand": "pnpm install",
  "outputDirectory": ".next",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- apps/web/ packages/agents/ pnpm-lock.yaml",
  "github": {
    "silent": true
  }
}
