# Google AI Studio (Gemini 2.0 Flash) — primary LLM provider
# Required. Get a free key at https://aistudio.google.com — no credit card needed
GOOGLE_AI_API_KEY=

# Groq (Llama 3.3 70B) — fallback LLM provider
# Required (as fallback). Get a free key at https://console.groq.com — no credit card needed
GROQ_API_KEY=

# LLM provider selection
# "google" (default) = try Gemini first, fall back to Groq
# "groq" = use Groq only (for testing)
LLM_PROVIDER=google

# Upstash Redis (rate limiting)
# Required. Create a database at https://console.upstash.com — use REST API credentials
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Sentry (error tracking)
# Get your DSN at https://sentry.io
SENTRY_DSN=

# Optional: PostHog (product analytics)
# Get your key and host at https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=